# Plantilla de .env para PRODUCCIÓN (shared hosting).
# Copiar a ".env" en el servidor y completar los valores reales.
# NO commitear el .env real: tiene credenciales.

APP_NAME="Agus Club"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Montevideo

# URL pública del backoffice (con https). Ej: https://admin.agus.club
APP_URL=https://TU-DOMINIO

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_AR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# --- Base de datos (MySQL del hosting) ---
# Los valores salen del panel (cPanel "MySQL Databases"). Suelen venir con
# prefijo del usuario de hosting, ej: cpaneluser_agusclub / cpaneluser_agus.
# DB_HOST en shared hosting casi siempre es "localhost"; si falla la conexión,
# probar "127.0.0.1".
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=cpaneluser_agusclub
DB_USERNAME=cpaneluser_agus
DB_PASSWORD=

# Sin Redis en shared hosting: todo a la DB.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Dominio de la cookie de sesión, ej: .agus.club
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
CACHE_PREFIX=agus

# --- Email ---
# Empezar con "log" (no manda nada, escribe en storage/logs). Cambiar a SMTP
# del hosting o a Postmark/Resend cuando se configure (Fase 1, PROMPT 8).
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hola@agus.club"
MAIL_FROM_NAME="${APP_NAME}"

# Storage de archivos: en shared hosting alcanza con "local" (FILESYSTEM_DISK
# arriba). Si más adelante se usa Cloudflare R2, completar esto.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true

# Búsqueda: driver database (Meilisearch no corre en shared hosting).
SCOUT_DRIVER=database

# Mercado Pago — completar con credenciales de PRODUCCIÓN (Fase 1, PROMPT 3/4).
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
