APP_NAME="Agus Club"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Montevideo
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_AR

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# MySQL — el hosting de producción es shared PHP con MySQL.
# Dev usa el contenedor mysql de docker-compose (raíz del repo).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=agus_club
DB_USERNAME=agus
DB_PASSWORD=agus_local

# Sin Redis en shared hosting: cache, queue y session van a la DB.
# Las migraciones por defecto de Laravel 11 ya crean las tablas necesarias.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=agus

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hola@agus.club"
MAIL_FROM_NAME="${APP_NAME}"

# Cloudflare R2 (S3-compatible) — completar en cada entorno.
# Alternativa válida en shared hosting: FILESYSTEM_DISK=local.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true

# Búsqueda: en Fase 1 se agrega Laravel Scout con driver "database"
# (Meilisearch no corre en shared hosting). Placeholder por ahora.
SCOUT_DRIVER=database

# Mercado Pago — completar con credenciales sandbox / prod.
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

VITE_APP_NAME="${APP_NAME}"
